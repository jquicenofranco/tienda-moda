# Normaliza los finales de línea: en el repositorio siempre se guardan con LF.
# Git los convierte al estilo del sistema operativo al hacer checkout.
* text=auto

# Archivos de código y texto -> LF en el repo
*.php   text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.sql   text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.xml   text eol=lf
*.txt   text eol=lf
*.env   text eol=lf
.gitignore      text eol=lf
.gitattributes  text eol=lf
.dockerignore   text eol=lf
Dockerfile      text eol=lf

# Scripts de shell -> SIEMPRE LF (se rompen con CRLF dentro de contenedores Linux)
*.sh    text eol=lf

# Archivos binarios -> sin conversión
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
