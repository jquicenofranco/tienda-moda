# =================================================================
#  Tienda Moda — Variables de entorno (EJEMPLO)
# =================================================================
#  Copia este archivo a ".env" y ajusta los valores según necesites.
#  El archivo real .env NO debe subirse al repositorio.
# =================================================================

# ---- Aplicación ----
# Puerto donde se expondrá la app en tu máquina local
APP_PORT=8080

# Ruta base de la app dentro del host.
# VACÍA = la app vive en la raíz   -> http://localhost:8080/
# "/tienda-moda"                  -> http://localhost:8080/tienda-moda/
APP_BASE_PATH=

# Entorno: production | development
APP_ENV=production

# ---- Base de datos MySQL ----
DB_HOST=db
DB_PORT=3306
DB_NAME=sistema_moda
DB_USER=tienda
DB_PASS=tienda_pass

# Usuario root de MySQL (solo para administración)
DB_ROOT_PASS=root_pass

# Puerto donde se expondrá MySQL en tu máquina local (para conectarte
# desde un cliente externo como HeidiSQL, Workbench, DBeaver, etc.)
DB_EXTERNAL_PORT=3307